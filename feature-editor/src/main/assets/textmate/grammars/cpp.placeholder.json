{
  "name": "C++ (placeholder)",
  "scopeName": "source.cpp",
  "fileTypes": ["cpp", "cc", "cxx", "hpp", "hh", "hxx"],
  "patterns": [
    {
      "match": "\\b(alignas|alignof|auto|bool|break|case|catch|char|class|const|constexpr|const_cast|continue|decltype|default|delete|do|double|dynamic_cast|else|enum|explicit|export|extern|false|float|for|friend|goto|if|inline|int|long|mutable|namespace|new|noexcept|nullptr|operator|private|protected|public|register|reinterpret_cast|return|short|signed|sizeof|static|static_assert|static_cast|struct|switch|template|this|thread_local|throw|true|try|typedef|typeid|typename|union|unsigned|using|virtual|void|volatile|wchar_t|while)\\b",
      "name": "keyword.control.cpp"
    },
    {
      "match": "^\\s*#\\s*(include|define|undef|if|ifdef|ifndef|else|elif|endif|pragma|error|warning|line)\\b",
      "name": "keyword.control.directive.cpp"
    },
    {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.cpp"
    },
    {
      "match": "//[^\\n]*",
      "name": "comment.line.double-slash.cpp"
    },
    {
      "begin": "/\\*",
      "end": "\\*/",
      "name": "comment.block.cpp"
    }
  ]
}
